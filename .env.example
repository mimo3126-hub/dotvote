# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Vercel Marketplace 통합으로 자동 설정됩니다 (수동 설정 시에만 입력)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 앱 베이스 URL (인쇄 시트 PDF의 QR 코드/URL에 사용)
NEXT_PUBLIC_APP_URL=https://dotvote.vercel.app

# Anthropic Claude vision (선택) — https://console.anthropic.com/settings/keys
# 미설정 시 사진 OCR은 Tesseract.js로 자동 폴백 (브라우저 사이드).
# 설정하면 Claude Haiku 4.5로 더 빠르고 정확한 인식 (특히 손글씨).
ANTHROPIC_API_KEY=

# 진행자 PIN (선택) — 기본값 1234
NEXT_PUBLIC_ADMIN_PIN=
